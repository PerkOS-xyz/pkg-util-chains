{
  "name": "@perkos/util-chains",
  "version": "1.0.0",
  "description": "Multi-chain configuration utilities for EVM networks with USDC support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "blockchain",
    "evm",
    "chains",
    "usdc",
    "multichain",
    "ethereum",
    "base",
    "polygon",
    "arbitrum",
    "optimism",
    "avalanche",
    "celo",
    "monad",
    "viem"
  ],
  "author": "PerkOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PerkOS-xyz/pkg-util-chains.git"
  },
  "dependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
